FROM python:3.14
WORKDIR /application
ENV PATH=/application/.venv/bin:$PATH
RUN git clone https://github.com/zhrkevin/quant.git /application
RUN pdm update --no-self --update-all --unconstrained --verbose
CMD bash run.sh
